# ==============================================
# ScanPilot Environment Configuration (Example)
# ==============================================
# Copy this file to .env and customize values
# ==============================================

# Server Configuration
SERVER_HOST=0.0.0.0                    # Backend server host
SERVER_PORT=8000                       # Backend API port

# Application Configuration
PROJECT_NAME=ScanPilot
VERSION=1.0.0
ENVIRONMENT=production                 # development | production | staging
DEBUG=False                           # Enable debug mode
API_V1_PREFIX=/api/v1

# Database Configuration
POSTGRES_PASSWORD=scanpilot_secure_password_2024
DATABASE_URL=postgresql://scanpilot_user:scanpilot_secure_password_2024@localhost:5432/scanpilot

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Security & Authentication
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480       # 8 hours
BCRYPT_ROUNDS=12

# Default Admin Credentials (CHANGE IN PRODUCTION!)
CREDENTIAL_ROOT_USER=admin
CREDENTIAL_ROOT_PASSWORD=change_this_password

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://localhost:3000","http://localhost","https://localhost"]

# File Storage
UPLOAD_MAX_SIZE=100MB
STORAGE_PATH=/app/storage

# Tools Configuration
TOOLS_PATH=/app/tools
MAX_CONCURRENT_SCANS=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/scanpilot.log

# Email Configuration (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=
EMAILS_FROM_NAME=ScanPilot

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security
BCRYPT_ROUNDS=12
JWT_ALGORITHM=HS256

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# WebSocket Configuration
WEBSOCKET_PING_INTERVAL=25
WEBSOCKET_PING_TIMEOUT=20